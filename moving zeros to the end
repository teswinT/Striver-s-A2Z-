# moving zeros to the end

def move_zeros(arr):

    length = len(arr)

    for i in range(-1,-length,-1):

        if arr[i] == 0:

            j = i
            while j <= -2 and arr[j+1] != 0:
                
                arr[j+1],arr[j] = arr[j],arr[j+1]
                j += 1




arr = [1,0,2,0,3,0,4,0,1]
print(arr)
move_zeros(arr)
print(arr)